{
  "databaseChangeLog": [
    {
      "changeSet": {
        "id": "002-Create-Commons-Features",
        "author": "abhi",
        "preConditions": [
          {
            "onFail": "MARK_RAN"
          },
          {
            "not": [
              {
                "tableExists": {
                  "tableName": "COMMONS_FEATURES"
                }
              }
            ]
          }
        ],
        "changes": [
          {
            "createTable": {
              "tableName": "COMMONS_FEATURES",
