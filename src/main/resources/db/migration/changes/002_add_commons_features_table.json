                      "nullable": false
                    },
                    "name": "COMMONS_ID",
                    "type": "BIGINT"
                  }
                },
                {
                  "column": {
                    "constraints": {
                      "nullable": false
                    },
                    "name": "FEATURE",
                    "type": "VARCHAR(255)"
                  }
                },
                {
                  "column": {
                    "constraints": {
                      "nullable": false
                    },
                    "name": "ENABLED",
                    "type": "BOOLEAN"
                  }
                }
              ]
            }
          },
          {
            "addUniqueConstraint": {
              "columnNames": "COMMONS_ID, FEATURE",
